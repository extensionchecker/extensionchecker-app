{
  "name": "@extensionchecker/frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build && node ../../scripts/generate-version.js dist",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "dev": "vite --host 0.0.0.0",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "@extensionchecker/shared": "0.1.0",
    "dompurify": "^3.3.3",
    "jspdf": "^4.2.1",
    "marked": "^18.0.0",
    "marked-alert": "^2.1.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260417.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.3",
    "jsdom": "^29.0.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.8",
    "vitest": "^4.1.4",
    "wrangler": "^4.83.0"
  }
}
