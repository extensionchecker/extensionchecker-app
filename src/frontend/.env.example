# Frontend environment variables
# See docs/DEPLOYMENT.md for details.

# Base URL for the backend API.
# In local development, leave blank — Vite proxies /api/* to 127.0.0.1:8787.
# In production Cloudflare Pages/Workers, leave blank — the frontend worker
# proxies via service binding.
# Only set this if the backend is hosted on a separate origin.
# VITE_API_BASE_URL=https://api.extensionchecker.org
