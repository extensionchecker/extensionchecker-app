# Backend environment variables
# See docs/DEPLOYMENT.md for details.
#
# These values can also be set via wrangler.toml [vars] or Cloudflare dashboard
# secrets for deployed Workers.

# Optional shared secret for API requests. If set, every request must
# include the header: x-extensionchecker-token.
# In the standard deployment, the frontend Worker injects this header
# automatically via its own copy of the secret — the browser never sees it.
# Set as an encrypted secret in the Cloudflare dashboard, not in plaintext.
# API_ACCESS_TOKEN=

# Comma-separated absolute origins allowed to call /api/* cross-origin.
# Same-origin requests (via the frontend Worker's service binding) are
# always permitted. Only needed if the backend is exposed publicly at its
# own domain and you want external browser-based callers.
# API_ALLOWED_ORIGINS=https://app.extensionchecker.org

# Set to "true" only for trusted server-to-server environments where
# requests arrive without an Origin header (e.g. curl, scripts).
# API_ALLOW_REQUESTS_WITHOUT_ORIGIN=false

# Rate-limit tuning (defaults shown):
# API_RATE_LIMIT_PER_MINUTE_PER_IP=30
# API_RATE_LIMIT_PER_DAY_PER_IP=2000
# API_RATE_LIMIT_GLOBAL_PER_DAY=90000
