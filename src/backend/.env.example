# Backend environment variables
# See docs/DEPLOYMENT.md for details.
#
# These values can also be set via wrangler.toml [vars] or Cloudflare dashboard
# secrets for deployed Workers.

# Comma-separated absolute origins allowed to call /api/* cross-origin.
# Same-origin requests are always permitted.
# API_ALLOWED_ORIGINS=https://app.extensionchecker.org

# Optional shared secret for API requests. If set, callers must provide
# header: x-extensionchecker-token.
# API_ACCESS_TOKEN=

# Set to "true" only for trusted server-to-server environments.
# API_ALLOW_REQUESTS_WITHOUT_ORIGIN=false

# Rate-limit tuning (defaults shown):
# API_RATE_LIMIT_PER_MINUTE_PER_IP=30
# API_RATE_LIMIT_PER_DAY_PER_IP=2000
# API_RATE_LIMIT_GLOBAL_PER_DAY=90000
